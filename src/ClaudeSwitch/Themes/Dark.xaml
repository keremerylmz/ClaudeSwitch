<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme — warm near-black surfaces, the same terracotta lifted slightly so it
         still reads as the accent against a dark ground. Same keys as Light.xaml. -->
    <SolidColorBrush x:Key="Bg"             Color="#1C1B1A"/>
    <SolidColorBrush x:Key="Surface"        Color="#242220"/>
    <SolidColorBrush x:Key="SurfaceHi"      Color="#302D2A"/>
    <SolidColorBrush x:Key="Border"         Color="#37342F"/>
    <SolidColorBrush x:Key="BorderStrong"   Color="#48443E"/>

    <SolidColorBrush x:Key="Text"           Color="#ECEAE5"/>
    <SolidColorBrush x:Key="TextSecondary"  Color="#B7B2AA"/>
    <SolidColorBrush x:Key="TextMuted"      Color="#87827A"/>

    <SolidColorBrush x:Key="Accent"         Color="#D97757"/>
    <SolidColorBrush x:Key="AccentHover"    Color="#E58B6C"/>
    <SolidColorBrush x:Key="AccentPressed"  Color="#C96442"/>
    <SolidColorBrush x:Key="AccentSoft"     Color="#2E251F"/>
    <SolidColorBrush x:Key="AccentBorder"   Color="#4C382C"/>

    <SolidColorBrush x:Key="Success"        Color="#5AA583"/>
    <SolidColorBrush x:Key="Warning"        Color="#D2A45E"/>
    <SolidColorBrush x:Key="Danger"         Color="#DB6A60"/>

    <SolidColorBrush x:Key="ScrollThumb"      Color="#403C37"/>
    <SolidColorBrush x:Key="ScrollThumbHover" Color="#57524B"/>

    <SolidColorBrush x:Key="TooltipBg"      Color="#0F0E0D"/>
    <SolidColorBrush x:Key="TooltipText"    Color="#ECEAE5"/>

</ResourceDictionary>
