<Window x:Class="ClaudeSwitch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ClaudeSwitch"
        Title="ClaudeSwitch"
        Height="640" Width="450"
        MinHeight="500" MinWidth="410"
        Background="{DynamicResource Bg}"
        FontFamily="{StaticResource UiFont}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════ Header ══════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                Padding="20,17,14,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="ClaudeSwitch"
                               FontSize="{StaticResource FontTitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text}"/>
                    <TextBlock x:Name="ActiveAccountText" Margin="0,3,0,0"
                               FontSize="{StaticResource FontSmall}"
                               Foreground="{DynamicResource TextMuted}"
                               TextTrimming="CharacterEllipsis"
                               Text="{loc:Tr app.loading}"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="SettingsButton" Style="{StaticResource IconButton}"
                        Content="⚙" FontSize="16" ToolTip="{loc:Tr tip.settings}"
                        Click="SettingsButton_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════ Account list ═══════════════════════ -->
        <ScrollViewer Grid.Row="1" Style="{StaticResource ListScroll}" Padding="16,14,16,6">
            <StackPanel>

                <ItemsControl x:Name="AccountList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="Card" Style="{StaticResource Card}">
                                <StackPanel>

                                    <!-- ── identity row ── -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="Avatar" Grid.Column="0"
                                                Width="36" Height="36" CornerRadius="18"
                                                Background="{DynamicResource SurfaceHi}"
                                                VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock x:Name="AvatarText" Text="{Binding Initial}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="{StaticResource FontStrong}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Text}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="Sub" Text="{Binding Subtitle}"
                                                       FontSize="{StaticResource FontSmall}" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,6,0">
                                            <Border Visibility="{Binding MostFreeVisibility}" CornerRadius="5"
                                                    Padding="7,3" Margin="0,0,5,0"
                                                    Background="{DynamicResource AccentSoft}"
                                                    BorderBrush="{DynamicResource AccentBorder}" BorderThickness="1">
                                                <TextBlock Text="{loc:Tr card.mostFree}"
                                                           FontSize="{StaticResource FontCaption}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Accent}"/>
                                            </Border>
                                            <Border Style="{StaticResource Badge}">
                                                <TextBlock Text="{Binding PlanBadge}" Style="{StaticResource BadgeText}"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button x:Name="UseButton" Style="{StaticResource GhostButton}"
                                                    Content="{loc:Tr card.switch}" Padding="13,6"
                                                    FontSize="{StaticResource FontSmall}"
                                                    Tag="{Binding}" Click="UseButton_Click"/>
                                            <Button Style="{StaticResource IconButton}" Content="⋯"
                                                    Width="26" Height="26" Margin="3,0,0,0"
                                                    ToolTip="{loc:Tr tip.more}"
                                                    Tag="{Binding}" Click="MoreButton_Click"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- ── usage panel (hidden in compact mode) ── -->
                                    <Border x:Name="UsageBox" Margin="0,12,0,0" Padding="12,11"
                                            CornerRadius="9"
                                            Visibility="{Binding UsageVisibility}"
                                            Background="{DynamicResource Surface}"
                                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                            ToolTip="{Binding UsageTooltip}">
                                        <StackPanel>

                                            <Grid>
                                                <TextBlock Text="{loc:Tr usage.fiveHour}" HorizontalAlignment="Left"
                                                           FontSize="{StaticResource FontSmall}"
                                                           Foreground="{DynamicResource TextMuted}"/>
                                                <TextBlock Text="{Binding FiveHourText}" HorizontalAlignment="Right"
                                                           FontSize="{StaticResource FontBody}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Text}"/>
                                            </Grid>
                                            <Border Height="5" Margin="0,6,0,0" CornerRadius="2.5"
                                                    Background="{DynamicResource SurfaceHi}" ClipToBounds="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding FiveHourStar}"/>
                                                        <ColumnDefinition Width="{Binding FiveHourRestStar}"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="2.5"
                                                            Background="{Binding FiveHourBrush}"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding FiveHourReset}" Margin="0,4,0,0"
                                                       FontSize="{StaticResource FontCaption}"
                                                       Foreground="{DynamicResource TextMuted}"/>

                                            <Grid Margin="0,12,0,0">
                                                <TextBlock Text="{loc:Tr usage.sevenDay}" HorizontalAlignment="Left"
                                                           FontSize="{StaticResource FontSmall}"
                                                           Foreground="{DynamicResource TextMuted}"/>
                                                <TextBlock Text="{Binding SevenDayText}" HorizontalAlignment="Right"
                                                           FontSize="{StaticResource FontBody}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Text}"/>
                                            </Grid>
                                            <Border Height="5" Margin="0,6,0,0" CornerRadius="2.5"
                                                    Background="{DynamicResource SurfaceHi}" ClipToBounds="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding SevenDayStar}"/>
                                                        <ColumnDefinition Width="{Binding SevenDayRestStar}"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="2.5"
                                                            Background="{Binding SevenDayBrush}"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding SevenDayReset}" Margin="0,4,0,0"
                                                       FontSize="{StaticResource FontCaption}"
                                                       Foreground="{DynamicResource TextMuted}"/>

                                            <Border Height="1" Margin="0,11,0,0" Background="{DynamicResource Border}"/>
                                            <Grid Margin="0,8,0,0">
                                                <TextBlock Text="{Binding UsageAsOf}" HorizontalAlignment="Left"
                                                           FontSize="{StaticResource FontCaption}"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <!-- 5-hour usage trend over recent samples. -->
                                                <Polyline HorizontalAlignment="Right" VerticalAlignment="Center"
                                                          Visibility="{Binding SparkVisibility}"
                                                          Points="{Binding SparkPoints}"
                                                          Stroke="{DynamicResource TextMuted}" StrokeThickness="1.4"
                                                          StrokeLineJoin="Round" Width="74" Height="16"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter TargetName="Card" Property="Background" Value="{DynamicResource AccentSoft}"/>
                                    <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource AccentBorder}"/>
                                    <Setter TargetName="Avatar" Property="Background" Value="{DynamicResource Accent}"/>
                                    <Setter TargetName="AvatarText" Property="Foreground" Value="White"/>
                                    <Setter TargetName="UsageBox" Property="Background" Value="{DynamicResource Bg}"/>
                                    <Setter TargetName="UseButton" Property="Content" Value="{loc:Tr card.active}"/>
                                    <Setter TargetName="UseButton" Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NeedsReauth}" Value="True">
                                    <Setter TargetName="Sub" Property="Foreground" Value="{DynamicResource Danger}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── empty state ── -->
                <Border x:Name="EmptyState" Visibility="Collapsed"
                        Background="{DynamicResource Surface}" CornerRadius="11"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        Padding="22,30" Margin="0,4,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="EmptyTitle" Text="{loc:Tr empty.title}"
                                   FontSize="{StaticResource FontStrong}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="EmptyBody" Margin="0,7,0,0" FontSize="{StaticResource FontBody}"
                                   TextAlignment="Center" TextWrapping="Wrap" LineHeight="18"
                                   Foreground="{DynamicResource TextMuted}"
                                   Text="{loc:Tr empty.body}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════ Footer ══════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                Padding="16,13">
            <StackPanel>

                <TextBlock x:Name="StatusText" Visibility="Collapsed"
                           FontSize="{StaticResource FontSmall}" Margin="2,0,2,11"
                           Foreground="{DynamicResource TextSecondary}"
                           TextWrapping="Wrap" LineHeight="17"/>

                <Border x:Name="CodePanel" Visibility="Collapsed" Margin="0,0,0,11"
                        Background="{DynamicResource AccentSoft}" CornerRadius="9"
                        BorderBrush="{DynamicResource AccentBorder}" BorderThickness="1"
                        Padding="13,11">
                    <StackPanel>
                        <TextBlock x:Name="CodeTitle" Text="{loc:Tr code.title}"
                                   FontSize="{StaticResource FontBody}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text}"/>
                        <TextBlock x:Name="CodeBody" Margin="0,5,0,0" FontSize="{StaticResource FontSmall}"
                                   TextWrapping="Wrap" LineHeight="17"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Text="{loc:Tr code.body}"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CodeBox" Grid.Column="0" Style="{StaticResource Field}"
                                     KeyDown="CodeBox_KeyDown"/>
                            <Button x:Name="SubmitCodeButton" Grid.Column="1" Margin="7,0,0,0"
                                    Style="{StaticResource PrimaryButton}" Content="{loc:Tr code.submit}"
                                    Padding="15,8" Click="SubmitCodeButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="9"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="SaveCurrentButton" Style="{StaticResource GhostButton}"
                            Content="{loc:Tr footer.saveCurrent}" Click="SaveCurrentButton_Click"/>
                    <Button Grid.Column="2" x:Name="AddAccountButton" Style="{StaticResource PrimaryButton}"
                            Content="{loc:Tr footer.addAccount}" Click="AddAccountButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
