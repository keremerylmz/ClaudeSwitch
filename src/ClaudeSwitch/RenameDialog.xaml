<Window x:Class="ClaudeSwitch.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename"
        Height="180" Width="360"
        Background="{StaticResource Bg}"
        FontFamily="{StaticResource UiFont}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="LabelText" Text="Display name"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>

        <TextBox Grid.Row="1" x:Name="NameBox" Margin="0,8,0,0" Padding="9,7" FontSize="13"
                 Foreground="{StaticResource Text}"
                 BorderBrush="{StaticResource Border}" BorderThickness="1"
                 Background="{StaticResource Bg}"
                 KeyDown="NameBox_KeyDown"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource GhostButton}" Content="Cancel"
                    IsCancel="True" Margin="0,0,8,0"/>
            <Button Style="{StaticResource PrimaryButton}" Content="Save"
                    IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
