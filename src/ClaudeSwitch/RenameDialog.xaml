<Window x:Class="ClaudeSwitch.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename"
        Width="380" SizeToContent="Height" MinHeight="170"
        Background="{DynamicResource Bg}"
        FontFamily="{StaticResource UiFont}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- SizeToContent so a longer label can never push the buttons off the window,
         which is exactly what a fixed height did before. -->
    <StackPanel Margin="22,20,22,18">

        <TextBlock x:Name="LabelText" Text="Display name"
                   FontSize="{StaticResource FontBody}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondary}"
                   TextWrapping="Wrap" LineHeight="18"/>

        <TextBox x:Name="NameBox" Style="{StaticResource Field}" Margin="0,10,0,0"
                 KeyDown="NameBox_KeyDown"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource GhostButton}" Content="Cancel"
                    IsCancel="True" Margin="0,0,8,0" Padding="16,8"/>
            <Button Style="{StaticResource PrimaryButton}" Content="Save"
                    IsDefault="True" Padding="18,8" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
